  "scoring": {
    "coreResponseValueRange": [-2, -1, 0, 1, 2],
    "traitVectorRange": [-2, 2],
    "coreQuestionFormula": "For each impact, selected A uses impact.a, selected B uses impact.b, neutral is 0. delta = sideValue * abs(responseValue / 2) * question.discrimination * impact.weight.",
    "normalizationFormula": "dimensionValue = clamp(2 * weightedSum / maxAbsWeight, -2, 2).",
    "calibrationFormula": "Q31 adds each selected option impact.value * impact.weight. Q32 subtracts each selected option impact.value * impact.weight. Clamp final dimensions to [-2, 2].",
    "animalRanking": {
      "prototypeFile": "animal_prototypes_v0_2.json",
      "distance": "sqrt(sum(dimensionWeight * (userDimension - animalPrototypeDimension)^2))",
      "probability": "softmax(-distance / temperature)",
      "temperature": 1.15
    },
    "resultPolicy": {
      "strongMainType": "P1 >= 0.24 and P1 - P2 >= 0.08",
      "mixedType": "P1 >= 0.20 and P1 - P2 < 0.08",
      "broadMixedType": "P1 < 0.20 with acceptable consistency",
      "secondaryCount": "Show 1 secondary animal when P1 - P2 >= 0.08, otherwise show 2 secondary animals."
    },
    "confidenceFormula": "confidence = 0.35 * dominance + 0.25 * consistency + 0.20 * completion + 0.20 * dimensionStability",
    "supplementalTrigger": "Trigger 4-8 extra questions when P1 - P2 < 0.06, P1 < 0.18, consistency < 0.62, or confidence < 0.58."
  }
